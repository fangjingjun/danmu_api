{
  "version": 2,
  "buildCommand": "sed -i '/key: key,/d' danmu_api/configs/handlers/vercel-handler.js",
  "builds": [
    {
      "src": "danmu_api/worker.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/danmu_api/worker.js"
    },
    {
      "src": "/api/(.*)",
      "dest": "/danmu_api/worker.js"
    },
    {
      "src": "/([^/]+)/api/(.*)",
      "dest": "/danmu_api/worker.js"
    },
    {
      "src": "/(.*)",
      "dest": "/danmu_api/worker.js"
    }
  ]
}
